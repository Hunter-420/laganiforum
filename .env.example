# Copy to Vercel → Project → Settings → Environment Variables
# https://vercel.com/docs/projects/environment-variables

# Required at runtime
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/laganiforum

AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=

ADMIN_EMAIL=admin@laganiforum.com
ADMIN_PASSWORD=change-me-strong-password

# Auth & security (use long random strings in production)
JWT_SECRET=generate-a-long-random-secret
AUTOMATION_API_KEY=

# Public site URL (canonical SEO, sitemaps, OG)
NEXT_PUBLIC_SITE_URL=https://laganiforum.com
NEXT_PUBLIC_APP_URL=https://laganiforum.com

# Optional
OPENAI_API_KEY=
ANALYTICS_SALT=
